{
  "name": "clawboard",
  "version": "0.53.0",
  "description": "AI驱动的本地剪贴板管理器 - 智能记录、语义搜索、永久收藏",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "clipboard",
    "electron",
    "ai",
    "ollama",
    "productivity",
    "local-first"
  ],
  "author": "NotSleeply",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "electron-updater": "^6.1.7",
    "qrcode-generator": "^2.0.4",
    "sql.js": "^1.10.0"
  },
  "build": {
    "appId": "com.notsleeply.clawboard",
    "productName": "ClawBoard",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "NotSleeply",
      "repo": "ClawBoard",
      "releaseType": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}
