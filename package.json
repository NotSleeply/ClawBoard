{
  "name": "clawboard",
  "version": "0.76.0",
  "description": "AI驱动的本地剪贴板管理器 CLI - 智能记录、语义搜索、永久收藏",
  "main": "src/cli/index.js",
  "bin": {
    "clawboard": "src/cli/index.js"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "lint": "eslint src/ --ext .js,.jsx --max-warnings 100",
    "lint:fix": "eslint src/ --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json}\"",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "clipboard",
    "cli",
    "ai",
    "ollama",
    "productivity",
    "local-first"
  ],
  "author": "NotSleeply",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "crypto-js": "^4.2.0",
    "lz-string": "^1.5.0",
    "qrcode-generator": "^2.0.4",
    "sql.js": "^1.10.0",
    "tesseract.js": "^7.0.0"
  },
  "files": [
    "src/**/*",
    "assets/**/*"
  ]
}
