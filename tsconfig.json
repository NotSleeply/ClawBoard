{
  "compilerOptions": {
    "target": "es2022",
    "module": "Node16",
    "lib": ["es2022", "dom"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "types": ["node", "jest"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "build", "src/renderer/app.js", "src/main/index.js"]
}
