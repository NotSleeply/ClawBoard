{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "lib": [
      "es2022",
      "dom"
    ],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "moduleResolution": "bundler",
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "src/renderer/app.js",
    "src/main/index.js"
  ]
}